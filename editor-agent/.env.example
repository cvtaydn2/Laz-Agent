NVIDIA_API_KEY=your-nvidia-key-here
NVIDIA_MODEL=moonshotai/kimi-k2-instruct
NVIDIA_FALLBACK_MODEL=minimaxai/minimax-m2.7
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Agent Performance Settings
AGENT_TIMEOUT_SECONDS=120
AGENT_MAX_FILE_BYTES=500000
AGENT_MAX_CHARS_PER_FILE=10000
AGENT_MAX_CONTEXT_CHARS=40000
AGENT_TOP_K_FILES=15
AGENT_MAX_COMPLETION_TOKENS=4096
AGENT_TEMPERATURE=0.1

# Server Settings
AGENT_SERVER_HOST=127.0.0.1
AGENT_SERVER_PORT=8000

# Optional: set a bearer token to protect the /v1/* proxy endpoints.
# Leave empty (or unset) to disable auth — safe for local-only use.
PROXY_API_KEY=
